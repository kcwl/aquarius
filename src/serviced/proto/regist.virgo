message regist -> 9000
{
	request
	{
		string name;
		string host;
		int32 port;
		bool healthy;
		string group;
		int32 weight;
		string version;
	}
	response
	{
	}
}

message subscribe_service -> 9001
{
	request
	{
		string group;
	}
	response
	{
		repeated uint64_t instances;
	}
}

message broad_service_status -> 9002
{
	request{}
	response
	{
		string group;
		uint64 host_and_port;
		bool healty;
	}
}