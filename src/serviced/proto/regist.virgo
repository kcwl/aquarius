message regist -> 9000
{
	request
	{
		string name;
		string host;
		int32 port;
		bool healthy;
		string group;
		int32 weight;
		string version;
	}
	response
	{
	}
}

struct instance
{
	string host;
	int32 port;
}

message subscribe_service -> 9001
{
	request
	{
		string group;
	}
	response
	{
		repeated instance instances;
	}
}

message broad_service_status -> 9002
{
	request{}
	response
	{
		string group;
		string host;
		int32 port;
		bool healty;
	}
}